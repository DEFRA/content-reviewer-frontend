{% extends 'layouts/page.njk' %}

{% from "govuk/components/notification-banner/macro.njk" import govukNotificationBanner %}

{% block content %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      
      {% if showConfirmation %}
        {{ govukNotificationBanner({
          type: "success",
          html: '<p class="govuk-notification-banner__heading">Your cookie settings were saved</p>
                 <p class="govuk-body">Government services may set additional cookies and, if so, will have their own cookie policy and banner.</p>'
        }) }}
      {% endif %}
      
      <h1 class="govuk-heading-xl">Cookies on AI Content Review</h1>
      
      <p class="govuk-body">Cookies are small files saved on your phone, tablet or computer when you visit a website.</p>
      
      <p class="govuk-body">We use essential cookies only. We do not use analytics or tracking cookies.</p>

      <h2 class="govuk-heading-l">Essential cookies</h2>
      
      <p class="govuk-body">Essential cookies keep your information secure while you use this service. We do not need to ask permission to use them.</p>
      
      <p class="govuk-body">These essential cookies do things like:</p>
      
      <ul class="govuk-list govuk-list--bullet">
        <li>keep you signed in securely using your Defra (Microsoft) account</li>
        <li>maintain your session as you move through the service</li>
        <li>remember that you have seen our cookie message</li>
      </ul>
      
      <p class="govuk-body">They always need to be on.</p>
      
      <h3 class="govuk-heading-m govuk-!-margin-top-6">Strictly necessary cookies</h3>
      
      <table class="govuk-table">
        <caption class="govuk-table__caption govuk-table__caption--m govuk-visually-hidden">Strictly necessary cookies</caption>
        <thead class="govuk-table__head">
          <tr class="govuk-table__row">
            <th scope="col" class="govuk-table__header">Name</th>
            <th scope="col" class="govuk-table__header">Purpose</th>
            <th scope="col" class="govuk-table__header">Expires</th>
          </tr>
        </thead>
        <tbody class="govuk-table__body">
          <tr class="govuk-table__row">
            <td class="govuk-table__cell">content-reviewer-session</td>
            <td class="govuk-table__cell">
              Keeps you signed in using your Defra (Microsoft) account and maintains your session securely as you use the service.
              The cookie is encrypted and HttpOnly — it cannot be read by browser scripts.
              Your session is automatically extended while you are active.
            </td>
            <td class="govuk-table__cell">10 hours, or when you sign out</td>
          </tr>
          <tr class="govuk-table__row">
            <td class="govuk-table__cell">cookie_preferences</td>
            <td class="govuk-table__cell">Remembers that you have seen our cookie message</td>
            <td class="govuk-table__cell">90 days</td>
          </tr>
        </tbody>
      </table>

      <h2 class="govuk-heading-l govuk-!-margin-top-9">Sign-in cookies set by Microsoft</h2>

      <p class="govuk-body">
        When you sign in using your Defra account, Microsoft (Azure Active Directory) may set its own cookies on
        <a class="govuk-link" href="https://login.microsoftonline.com" rel="noopener noreferrer">login.microsoftonline.com</a>
        to manage the sign-in process. These cookies are governed by
        <a class="govuk-link" href="https://privacy.microsoft.com/en-gb/privacystatement" rel="noopener noreferrer">Microsoft's privacy statement</a>
        and are not set or controlled by this service.
      </p>
      
      <h2 class="govuk-heading-l govuk-!-margin-top-9">Local storage</h2>
      
      <p class="govuk-body">We use your browser's local storage to save your AI chat conversation history. This is stored only on your device and is not sent to our servers.</p>
      
      <p class="govuk-body">Local storage is similar to cookies but is not sent to the server with each request. It remains on your device until you clear your browser data.</p>
      
      <table class="govuk-table">
        <caption class="govuk-table__caption govuk-table__caption--m govuk-visually-hidden">Local storage</caption>
        <thead class="govuk-table__head">
          <tr class="govuk-table__row">
            <th scope="col" class="govuk-table__header">Name</th>
            <th scope="col" class="govuk-table__header">Purpose</th>
            <th scope="col" class="govuk-table__header">Expires</th>
          </tr>
        </thead>
        <tbody class="govuk-table__body">
          <tr class="govuk-table__row">
            <td class="govuk-table__cell">conversations</td>
            <td class="govuk-table__cell">Stores your AI chat conversation history on your device only (not sent to our servers)</td>
            <td class="govuk-table__cell">When you clear your browser data</td>
          </tr>
        </tbody>
      </table>
      
      <p class="govuk-body">You can clear your local storage by:</p>
      
      <ul class="govuk-list govuk-list--bullet">
        <li>clearing your browser's cache and cookies</li>
        <li>using your browser's developer tools (F12 → Application → Local Storage)</li>
        <li>using your browser's privacy settings to clear site data</li>
      </ul>
      
      <div class="govuk-inset-text">
        <p class="govuk-body">Note: Local storage is essential for the AI chat feature to work. If you clear it, your conversation history will be lost.</p>
      </div>
      
    </div>
  </div>
{% endblock %}
