{% extends 'layouts/page.njk' %}

{% from "govuk/components/notification-banner/macro.njk" import govukNotificationBanner %}

{% block content %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">

      {% if showConfirmation %}
        {{ govukNotificationBanner({
          type: "success",
          html: '<p class="govuk-notification-banner__heading">Your cookie settings were saved</p>'
        }) }}
      {% endif %}

      <h1 class="govuk-heading-xl">Cookies on AI Content Review</h1>

      <p class="govuk-body">Cookies are small files saved on your phone, tablet or computer when you visit a website.</p>

      <p class="govuk-body">We use essential cookies to make this service work. We do not use analytics or tracking cookies.</p>

      <h2 class="govuk-heading-l">Essential cookies</h2>

      <p class="govuk-body">Essential cookies keep your information secure while you use this service. We do not need to ask permission to use them.</p>

      <p class="govuk-body">These cookies do things like:</p>

      <ul class="govuk-list govuk-list--bullet">
        <li>keep you signed in securely using your Defra Microsoft account</li>
        <li>keep your session active while you use the tool</li>
        <li>remember that you have dismissed our cookie message</li>
      </ul>

      <p class="govuk-body">They always need to be on.</p>

      <table class="govuk-table govuk-!-margin-top-6">
        <caption class="govuk-table__caption govuk-table__caption--m">Essential cookies</caption>
        <thead class="govuk-table__head">
          <tr class="govuk-table__row">
            <th scope="col" class="govuk-table__header">Name</th>
            <th scope="col" class="govuk-table__header">Purpose</th>
            <th scope="col" class="govuk-table__header">Expires</th>
          </tr>
        </thead>
        <tbody class="govuk-table__body">
          <tr class="govuk-table__row">
            <td class="govuk-table__cell">content-reviewer-session</td>
            <td class="govuk-table__cell">Stores your authentication credentials after you sign in with your Defra Microsoft account. Encrypted and HttpOnly — cannot be read by browser scripts.</td>
            <td class="govuk-table__cell">1 hour of inactivity, or when you sign out</td>
          </tr>
          <tr class="govuk-table__row">
            <td class="govuk-table__cell">__Host-session</td>
            <td class="govuk-table__cell">Maintains your server-side session, including the return URL after sign-in. Encrypted and stored server-side.</td>
            <td class="govuk-table__cell">1 hour of inactivity</td>
          </tr>
          <tr class="govuk-table__row">
            <td class="govuk-table__cell">cookie_preferences</td>
            <td class="govuk-table__cell">Remembers that you have dismissed the cookie information banner so it is not shown again. Readable by the cookie banner script to show or hide the banner.</td>
            <td class="govuk-table__cell">90 days</td>
          </tr>
        </tbody>
      </table>

      <h2 class="govuk-heading-l govuk-!-margin-top-9">Sign-in cookies set by Microsoft</h2>

      <p class="govuk-body">When you sign in using your Defra Microsoft account, Microsoft (Azure Active Directory) may set its own cookies on <a class="govuk-link" href="https://login.microsoftonline.com" rel="noopener noreferrer" target="_blank">login.microsoftonline.com (opens in new tab)</a> to manage the sign-in process. These cookies are governed by <a class="govuk-link" href="https://privacy.microsoft.com/en-gb/privacystatement" rel="noopener noreferrer" target="_blank">Microsoft's privacy statement (opens in new tab)</a> and are not set or controlled by this service.</p>

      <h2 class="govuk-heading-l govuk-!-margin-top-9">Review history</h2>

      <p class="govuk-body">Your review history is stored securely on our servers, not in your browser. You can view up to 100 of your most recent reviews. Reviews older than 5 days are automatically deleted from our systems.</p>

    </div>
  </div>
{% endblock %}
