{% extends 'layouts/page.njk' %}

{% from "govuk/components/radios/macro.njk" import govukRadios %}
{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/notification-banner/macro.njk" import govukNotificationBanner %}

{% block content %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      
      {% if showConfirmation %}
        {{ govukNotificationBanner({
          type: "success",
          html: '<p class="govuk-notification-banner__heading">Your cookie settings were saved</p>
                 <p class="govuk-body">Government services may set additional cookies and, if so, will have their own cookie policy and banner.</p>'
        }) }}
      {% endif %}
      
      <h1 class="govuk-heading-xl">Cookies on AI Content Review</h1>
      
      <p class="govuk-body">Cookies are small files saved on your phone, tablet or computer when you visit a website.</p>
      
      <p class="govuk-body">We use cookies to make this service work and collect information about how you use our service.</p>
      
      <h2 class="govuk-heading-l">Cookie settings</h2>
      
      <p class="govuk-body">We use 2 types of cookie. You can choose which cookies you're happy for us to use.</p>
      
      <form method="post" action="/cookies" novalidate>
        
        <h3 class="govuk-heading-m">Cookies that measure website use</h3>
        
        <p class="govuk-body">We use Google Analytics to measure how you use the service so we can improve it based on user needs. We do not allow Google to use or share this data for their own purposes.</p>
        
        <p class="govuk-body">Google Analytics sets cookies that store anonymised information about:</p>
        
        <ul class="govuk-list govuk-list--bullet">
          <li>how you got to the service</li>
          <li>the pages you visit on the service and how long you spend on each page</li>
          <li>what you click on while you're using the service</li>
        </ul>
        
        {{ govukRadios({
          name: "analytics",
          fieldset: {
            legend: {
              text: "Do you want to accept analytics cookies?",
              classes: "govuk-fieldset__legend--s"
            }
          },
          items: [
            {
              value: "yes",
              text: "Yes",
              checked: analyticsCookies === 'yes'
            },
            {
              value: "no",
              text: "No",
              checked: analyticsCookies === 'no' or not analyticsCookies
            }
          ]
        }) }}
        
        <h3 class="govuk-heading-m govuk-!-margin-top-6">Strictly necessary cookies</h3>
        
        <p class="govuk-body">These essential cookies do things like:</p>
        
        <ul class="govuk-list govuk-list--bullet">
          <li>remember your progress through the service</li>
          <li>keep your information secure while you use the service</li>
          <li>remember your cookie consent preferences</li>
        </ul>
        
        <p class="govuk-body">They always need to be on.</p>
        
        <p class="govuk-body"><a href="#cookie-details" class="govuk-link">Find out more about cookies on AI Content Review</a></p>
        
        {{ govukButton({
          text: "Save cookie settings"
        }) }}
        
      </form>
      
      <h2 class="govuk-heading-l govuk-!-margin-top-9" id="cookie-details">How cookies are used on AI Content Review</h2>
      
      <h3 class="govuk-heading-m">Strictly necessary cookies</h3>
      
      <p class="govuk-body">We use essential cookies to make this service work. We do not need to ask permission to use them.</p>
      
      <table class="govuk-table">
        <caption class="govuk-table__caption govuk-table__caption--m govuk-visually-hidden">Strictly necessary cookies</caption>
        <thead class="govuk-table__head">
          <tr class="govuk-table__row">
            <th scope="col" class="govuk-table__header">Name</th>
            <th scope="col" class="govuk-table__header">Purpose</th>
            <th scope="col" class="govuk-table__header">Expires</th>
          </tr>
        </thead>
        <tbody class="govuk-table__body">
          <tr class="govuk-table__row">
            <td class="govuk-table__cell">session</td>
            <td class="govuk-table__cell">Used to keep you signed in and maintain your session as you use the service</td>
            <td class="govuk-table__cell">4 hours</td>
          </tr>
          <tr class="govuk-table__row">
            <td class="govuk-table__cell">cookie_preferences</td>
            <td class="govuk-table__cell">Remembers your cookie consent choices so we do not ask you again</td>
            <td class="govuk-table__cell">90 days</td>
          </tr>
        </tbody>
      </table>
      
      <h3 class="govuk-heading-m">Analytics cookies (optional)</h3>
      
      <p class="govuk-body">With your permission, we use Google Analytics to collect data about how you use the service. This information helps us to improve our service.</p>
      
      <p class="govuk-body">Google is not allowed to use or share our analytics data with anyone.</p>
      
      <p class="govuk-body">Google Analytics stores anonymised information about:</p>
      
      <ul class="govuk-list govuk-list--bullet">
        <li>how you got to the service</li>
        <li>the pages you visit on the service, and how long you spend on each page</li>
        <li>what you click on while you're visiting the service</li>
        <li>the device and browser you use</li>
      </ul>
      
      <table class="govuk-table">
        <caption class="govuk-table__caption govuk-table__caption--m govuk-visually-hidden">Analytics cookies</caption>
        <thead class="govuk-table__head">
          <tr class="govuk-table__row">
            <th scope="col" class="govuk-table__header">Name</th>
            <th scope="col" class="govuk-table__header">Purpose</th>
            <th scope="col" class="govuk-table__header">Expires</th>
          </tr>
        </thead>
        <tbody class="govuk-table__body">
          <tr class="govuk-table__row">
            <td class="govuk-table__cell">_ga</td>
            <td class="govuk-table__cell">Used to distinguish users</td>
            <td class="govuk-table__cell">2 years</td>
          </tr>
          <tr class="govuk-table__row">
            <td class="govuk-table__cell">_gid</td>
            <td class="govuk-table__cell">Used to distinguish users</td>
            <td class="govuk-table__cell">24 hours</td>
          </tr>
          <tr class="govuk-table__row">
            <td class="govuk-table__cell">_gat</td>
            <td class="govuk-table__cell">Used to throttle request rate</td>
            <td class="govuk-table__cell">1 minute</td>
          </tr>
        </tbody>
      </table>
      
      <h3 class="govuk-heading-m">Local storage</h3>
      
      <p class="govuk-body">We also use your browser's local storage to save your conversation history. This is stored only on your device and is not sent to our servers.</p>
      
      <table class="govuk-table">
        <caption class="govuk-table__caption govuk-table__caption--m govuk-visually-hidden">Local storage</caption>
        <thead class="govuk-table__head">
          <tr class="govuk-table__row">
            <th scope="col" class="govuk-table__header">Name</th>
            <th scope="col" class="govuk-table__header">Purpose</th>
            <th scope="col" class="govuk-table__header">Expires</th>
          </tr>
        </thead>
        <tbody class="govuk-table__body">
          <tr class="govuk-table__row">
            <td class="govuk-table__cell">conversations</td>
            <td class="govuk-table__cell">Stores your AI chat conversation history on your device only</td>
            <td class="govuk-table__cell">When you clear your browser data</td>
          </tr>
        </tbody>
      </table>
      
      <p class="govuk-body">You can clear your local storage by clearing your browser's data or using your browser's developer tools.</p>
      
    </div>
  </div>
{% endblock %}
