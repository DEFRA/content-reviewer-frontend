          });
        } else {
          // No pagination needed: show all returned items
          pagedReviews = normalized;
        }

        // Update the table with the review data
        updateReviewTable(pagedReviews);
        
        // Check if there are still active reviews (pending or processing, not completed or failed)
        const activeReviews = normalized.filter(r => {
