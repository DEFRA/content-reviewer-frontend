{% extends "layouts/page.njk" %}

{% from "govuk/components/button/macro.njk" import govukButton %}

{% block content %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">

      <h1 class="govuk-heading-l">Sign in</h1>

      {% if errorMessage %}
        <div class="govuk-error-summary" aria-labelledby="error-summary-title" role="alert" tabindex="-1" data-module="govuk-error-summary">
          <h2 class="govuk-error-summary__title" id="error-summary-title">
            There is a problem
          </h2>
          <div class="govuk-error-summary__body">
            <ul class="govuk-list govuk-error-summary__list">
              <li>{{ errorMessage }}</li>
            </ul>
          </div>
        </div>
      {% endif %}

      <p class="govuk-body-l">An AI-powered content review tool that helps ensure your content meets GOV.UK standards.</p>

      <p class="govuk-body">The Content Review Tool helps you:</p>
      <ul class="govuk-list govuk-list--bullet">
        <li>Review content for plain English and clarity</li>
        <li>Check compliance with GOV.UK style guidelines</li>
        <li>Identify areas for improvement in readability</li>
        <li>Get AI-powered suggestions for better content</li>
      </ul>

      <div class="govuk-inset-text">
        <strong>Sign in is optional.</strong> You can use this tool without signing in. Your review history will be saved for your current session. Sign in with your Defra credentials to save your reviews permanently across sessions.
      </div>

      <p class="govuk-body">Click on the button below to log in using your Defra credentials, or <a href="/" class="govuk-link">return to the home page</a> to continue without signing in.</p>

      {{ govukButton({
        text: "Log in",
        href: "/auth/login",
        isStartButton: true,
        classes: "govuk-!-margin-top-2"
      }) }}

      <p class="govuk-body govuk-!-margin-top-4">
        <a href="/" class="govuk-link">Continue without signing in</a>
      </p>

    </div>
  </div>
{% endblock %}
