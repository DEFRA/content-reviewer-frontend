{% extends "layouts/page.njk" %}

{% block content %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      <h1 class="govuk-heading-l">{{ heading }}</h1>

      <div class="govuk-inset-text" id="status-message">
        <p class="govuk-body">
          Please wait while we scan and process your document. This may take a few moments.
        </p>
      </div>

      <div id="spinner" class="govuk-!-margin-bottom-4">
        <p class="govuk-body">Checking upload status...</p>
      </div>

      <div id="error-container" hidden>
        <div class="govuk-error-summary" aria-labelledby="error-summary-title" role="alert">
          <h2 class="govuk-error-summary__title" id="error-summary-title">
            There is a problem
          </h2>
          <div class="govuk-error-summary__body">
            <p class="govuk-body" id="error-message"></p>
          </div>
        </div>
        <p class="govuk-body">
          <a href="/" class="govuk-link">Back to home</a>
        </p>
      </div>
    </div>
  </div>

  <script nonce="{{ cspNonce }}">
    (function() {
      const uploadId = '{{ uploadId | safe }}';
      const reviewId = '{{ reviewId | safe }}';
      const maxAttempts = 30;
      const pollInterval = 2000;
      let attempts = 0;

      function showError(message) {
        document.getElementById('spinner').hidden = true;
        document.getElementById('status-message').hidden = true;
        document.getElementById('error-message').textContent = message;
        document.getElementById('error-container').hidden = false;
      }

      function goToReview() {
        var reviewUrl = '/review/status-poller/' + encodeURIComponent(reviewId);
        if (!uploadId) {
          // Session lost — cannot call trigger-review without uploadId; navigate
          // directly and let the review poller handle the missing state.
          window.location.href = reviewUrl;
          return;
        }
        // Step c: call our server with the uploadId so it can fetch the S3 URL
        // from CDP Uploader status and forward it to the backend for canonical
        // document creation, SQS queuing, and Bedrock AI review.
        fetch('/upload/trigger-review', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          credentials: 'same-origin',
          body: JSON.stringify({ uploadId: uploadId, reviewId: reviewId })
        }).then(function() {
          window.location.href = reviewUrl;
        }).catch(function() {
          // Still navigate even if the trigger call fails — the review poller
          // will surface any processing errors to the user.
          window.location.href = reviewUrl;
        });
      }

      function pollStatus() {
        fetch('/upload/status/' + encodeURIComponent(uploadId), { credentials: 'same-origin' })
          .then(function(response) {
            if (!response.ok) {
              throw new Error('Failed to check upload status');
            }
            return response.json();
          })
          .then(function(data) {
            if (data.uploadStatus === 'ready') {
              // CDP Uploader has scanned the file and stored it in S3.
              // goToReview calls /upload/trigger-review (step c) which forwards
              // the S3 URL to the backend to start the processing pipeline.
              goToReview();
            } else if (data.uploadStatus === 'rejected') {
              var errorMsg = (data.form && data.form.file && data.form.file.errorMessage)
                ? data.form.file.errorMessage
                : 'Your document was rejected. Please check the file type and size and try again.';
              showError(errorMsg);
            } else {
              attempts++;
              if (attempts < maxAttempts) {
                setTimeout(pollStatus, pollInterval);
              } else {
                showError('Upload processing timed out. Please try again.');
              }
            }
          })
          .catch(function() {
            showError('An error occurred while checking upload status. Please try again.');
          });
      }

      if (!uploadId) {
        // Session was lost (e.g. page refresh after session expiry).
        // If we still have the reviewId, go straight to the review poller —
        // the backend callback will have already queued the job.
        if (reviewId) {
          goToReview();
        } else {
          showError('Upload session not found. Please try uploading again.');
        }
      } else {
        // Start polling after a short delay to give CDP Uploader time to process
        setTimeout(pollStatus, 1000);
      }
    })();
  </script>
{% endblock %}
