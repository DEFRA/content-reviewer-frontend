{% extends "layouts/page.njk" %}

{% block content %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">

      {% if successMessage %}

        <div class="govuk-panel govuk-panel--confirmation">
          <h1 class="govuk-panel__title">Review deleted</h1>
          <div class="govuk-panel__body">{{ successMessage }}</div>
        </div>

      {% else %}

        <h1 class="govuk-heading-l">Are you sure you want to delete this review?</h1>

        {% if errorMessage %}
          <div class="govuk-error-summary" data-module="govuk-error-summary">
            <div role="alert">
              <h2 class="govuk-error-summary__title">There is a problem</h2>
              <div class="govuk-error-summary__body">
                <p class="govuk-body">{{ errorMessage }}</p>
              </div>
            </div>
          </div>
        {% endif %}

        <p class="govuk-body">
          This will permanently delete <strong>{{ filename }}</strong> from your review history.
        </p>

        <hr class="govuk-section-break govuk-section-break--m govuk-section-break--visible">

        <form method="POST" action="/review/history/{{ reviewId }}/delete">
          <input type="hidden" name="filename" value="{{ filename }}">
          <button type="submit" class="govuk-button govuk-button--warning" data-module="govuk-button">
            Delete
          </button>
        </form>

        <a href="/" class="govuk-back-link">Cancel and go back</a>

      {% endif %}

    </div>
  </div>
{% endblock %}
