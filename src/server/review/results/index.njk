{% extends "layouts/page.njk" %}

{% block content %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-full">
      
      <h1 class="govuk-heading-xl">{{ heading }}</h1>
      
      <!-- Overall Status Banner -->
      {% set status = results.status or 'unknown' %}
      {% set statusClass =
        ('govuk-tag--green' if status == 'completed' else
        ('govuk-tag--red' if status == 'failed' else 
        ('govuk-tag--yellow' if status == 'processing' else 'govuk-tag--blue'))) %}
      
      <div class="govuk-notification-banner" role="region" data-module="govuk-notification-banner">
        <div class="govuk-notification-banner__content govuk-notification-banner__content--success">
          <h2 class="govuk-notification-banner__heading">
            Overall Status: <strong class="govuk-tag {{ statusClass }}">{{ status | replace('_', ' ') | title }}</strong>
          </h2>
        </div>
      </div>

      <!-- AI Review Content -->
      <!-- 🔍 DEBUG: Show data structure for debugging -->
      <details class="govuk-details" data-module="govuk-details">
        <summary class="govuk-details__summary">
          <span class="govuk-details__summary-text">
            🔍 DEBUG: Review Data Structure
          </span>
        </summary>
        <div class="govuk-details__text">
          <pre style="background: #f3f2f1; padding: 10px; overflow: auto; max-height: 300px;">
results exists: {{ 'true' if results else 'false' }}
results.result exists: {{ 'true' if results.result else 'false' }}
results.result.reviewData exists: {{ 'true' if results.result.reviewData else 'false' }}
results.result.reviewData type: {{ results.result.reviewData.__class__.__name__ if results.result.reviewData else 'N/A' }}

Full results object:
{{ results | dump(2) }}
          </pre>
        </div>
      </details>

      {% if results.result and results.result.reviewData %}
        <div class="review-results-container">
          {% set reviewData = results.result.reviewData %}
          {% include "review/results/review-output.njk" %}
        </div>
      {% else %}
        <div class="govuk-warning-text">
          <span class="govuk-warning-text__icon" aria-hidden="true">!</span>
          <strong class="govuk-warning-text__text">
            <span class="govuk-warning-text__assistive">Warning</span>
            No review content available
          </strong>
        </div>
      {% endif %}

      <!-- Actions -->
      <div class="govuk-button-group govuk-!-margin-top-6">
        <a href="/" class="govuk-button" data-module="govuk-button">
          Review Another Document
        </a>
      </div>

    </div>
  </div>
{% endblock %}

{% block bodyEnd %}
  {{ super() }}
{% endblock %}
