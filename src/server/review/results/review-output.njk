{# 
  Review Output Component
  Renders structured review data from result/{reviewId}.json

  Data structure (passed as 'reviewData'):
  {
    scores: {
      "Plain English":          { score: 4, note: "" },
      "GOV.UK Style Compliance": { score: 3, note: "" }
    },
    reviewedContent: {
      annotatedSections: [
        { text: "The department should ", issueIdx: null, category: null },
        { text: "utilise",               issueIdx: 0,    category: "plain-english" },
        { text: " all resources",         issueIdx: null, category: null }
      ],
      issues: [
        { issueId, absStart, absEnd, category, severity, why, suggested, evidence }
      ]
    },
    improvements: [
      { issueId, severity, category, issue, why, current, suggested }
    ]
  }
#}

<div class="review-output">

  {# ── Scorecard ────────────────────────────────────────────────────────── #}
  {% if reviewData.scores %}
    {#
      data-remember-expanded="false" disables GOV.UK Frontend's default behaviour
      of restoring the user's previous expand/collapse state from localStorage.
      Combined with the markup-level `aria-expanded="false"` below, this guarantees
      the scorecard always loads collapsed on a real page load — first visit,
      refresh, or navigation to a different review ID.

      Note: When the browser restores the page from its in-memory back/forward
      cache (bfcache) the DOM is replayed as-is — no JS runs — so an expanded
      scorecard will reappear expanded after a back-button click. This is
      standard browser behaviour, not specific to this app. Resolving it would
      need an inline script gated by a CSP nonce, which is currently out of
      scope.
    #}
    <div class="govuk-accordion" data-module="govuk-accordion" data-remember-expanded="false" id="accordion-scores">
      <div class="govuk-accordion__section">
        <div class="govuk-accordion__section-header">
          <h2 class="govuk-accordion__section-heading">
            <button type="button" id="accordion-scores-heading-1"
                    aria-controls="accordion-scores-content-1"
                    class="govuk-accordion__section-button"
                    aria-expanded="false">
              Content scorecard
            </button>
          </h2>
        </div>
        <div id="accordion-scores-content-1"
             class="govuk-accordion__section-content"
             aria-labelledby="accordion-scores-heading-1">
          <dl class="govuk-summary-list">
            {% for category, scoreData in reviewData.scores %}
              <div class="govuk-summary-list__row">
                <dt class="govuk-summary-list__key">{{ category }}</dt>
                <dd class="govuk-summary-list__value">
                  <span class="score-value">{{ scoreData.score }}/5</span>
                  {% if scoreData.note %}
                    <span class="score-separator"> — </span>
                    <span class="score-note">{{ scoreData.note }}</span>
                  {% endif %}
                </dd>
              </div>
            {% endfor %}
          </dl>
        </div>
      </div>
    </div>

    <style>
      #accordion-scores .govuk-accordion__show-all { display: none !important; }

      .score-separator { color: #505a5f; font-weight: normal; }

      html { scroll-behavior: smooth; }

      /* Forward direction: highlight the improvement card when scrolled to. */
      .improvement-item:target {
        outline: 3px solid #1d70b8;
        outline-offset: 4px;
        background-color: #e8f4fd;
        border-radius: 4px;
      }

      /*
        Reverse direction: highlight the <mark> in "Your content" when the user
        clicks "Return to highlighted text" on an improvement card.
        A short pulse draws the eye so the user can see where they landed.
      */
      mark[id]:target {
        outline: 3px solid #1d70b8;
        outline-offset: 2px;
        animation: returnPulse 1.5s ease-out;
      }
      @keyframes returnPulse {
        0%   { background-color: #ffdd00; }
        100% { background-color: inherit; }
      }

      /* Leave room for any sticky header / cookie banner above an anchor target. */
      .improvement-item,
      mark[id] {
        scroll-margin-top: 80px;
      }

      /* "Return to highlighted text" link sits bottom-right of each card. */
      .return-to-text {
        text-align: right;
        margin-top: 0.5em;
        margin-bottom: 0;
      }

      /* Back-link adds no value on print — hide it. */
      @media print { .return-to-text { display: none; } }
    </style>
  {% endif %}

  {# ── Annotated content ───────────────────────────────────────────────── #}
  <section class="reviewed-content govuk-!-margin-top-6">
    <h2 class="govuk-heading-m">Your content (issues highlighted)</h2>

    {%- if reviewData.reviewedContent and reviewData.reviewedContent.annotatedSections
          and reviewData.reviewedContent.annotatedSections.length > 0 -%}
      {%- set assembledContent -%}
        {%- for section in reviewData.reviewedContent.annotatedSections -%}
          {%- if section.issueIdx is not null and section.issueIdx is not undefined -%}
            {#
              section.issueIdx is the sequential 0-based index produced by _sortAndAlignPairs.
              It is guaranteed to match loop.index0 of the improvements list below (1:1).
              We use this 1:1 mapping to look up the improvement's stable issueId UUID, which
              becomes the <mark>'s id — the target for the reverse "Return to highlighted text"
              link rendered in each improvement card below.
            #}
            {%- set categoryClass = 'highlight-' + (section.category | lower | replace(' ', '-')) -%}
            {%- set linkedImprovement = reviewData.improvements[section.issueIdx] -%}
            <a href="#improvement-{{ section.issueIdx }}" class="highlight-link" aria-label="Issue {{ section.issueIdx + 1 }}: {{ section.category }}"><mark{% if linkedImprovement and linkedImprovement.issueId %} id="{{ linkedImprovement.issueId }}"{% endif %} class="highlight-general {{ categoryClass }}">{{ section.text | renderUrlContent(true) | safe }}</mark></a>
          {%- else -%}
            {{ section.text | renderUrlContent(true) | safe }}
          {%- endif -%}
        {%- endfor -%}
      {%- endset -%}
      <div class="content-body govuk-body">
        {{ assembledContent | convertNewlines | safe }}
      </div>
    {%- else -%}
      <div class="content-body govuk-body"><p>No content available for annotation.</p></div>
    {%- endif -%}
  </section>

  {# ── Priority Improvements ───────────────────────────────────────────── #}
  <section class="example-improvements">
    <h2>Priority Improvements</h2>
    {% if reviewData.improvements and reviewData.improvements.length > 0 %}
      <ol class="improvement-list">
        {% for improvement in reviewData.improvements %}
          {# Backend enforces 1:1 validity; this guard is a safety net for any legacy stored data #}
          {% if improvement.suggested and improvement.suggested | trim and improvement.issue | lower != "issue identified" %}
            <li id="improvement-{{ loop.index0 }}" class="improvement-item severity-{{ improvement.severity }}">
              <span class="category-badge">{{ improvement.category }}</span>
              <strong class="issue-title">{{ improvement.issue }}</strong>
              <p class="issue-description">{{ improvement.why }}</p>
              {% if improvement.current or improvement.suggested %}
                <div class="issue-example">
                  {% if improvement.current %}
                    <p class="before-text"><strong>Current:</strong> {{ improvement.current }}</p>
                  {% endif %}
                  {% if improvement.suggested %}
                    <p class="after-text"><strong>Suggested:</strong> {{ improvement.suggested }}</p>
                  {% endif %}
                </div>
              {% endif %}
              {#
                Reverse-navigation link. Points to the matching <mark> in "Your content"
                via the improvement's stable issueId UUID. Rendered only when an issueId
                is present so a data inconsistency never produces a dead link.
              #}
              {% if improvement.issueId %}
                <p class="return-to-text">
                  <a href="#{{ improvement.issueId }}"
                     class="govuk-link govuk-link--no-visited-state"
                     aria-label="Return to issue {{ loop.index }} highlighted in your content">
                    Return to highlighted text
                  </a>
                </p>
              {% endif %}
            </li>
          {% endif %}
        {% endfor %}
      </ol>
    {% else %}
      <p class="govuk-body">No improvements suggested.</p>
    {% endif %}
  </section>

</div>
