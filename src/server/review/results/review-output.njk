{# 
  Review Output Component
  Renders structured review data from result/{reviewId}.json

  Data structure (passed as 'reviewData'):
  {
    scores: {
      "Accessibility": { score: 4, note: "" },
      "Style":         { score: 3, note: "" },
      "Tone":          { score: 5, note: "" },
      "Overall":       { score: 4, note: "" }
    },
    reviewedContent: {
      annotatedSections: [
        { text: "The department should ", issueIdx: null, category: null },
        { text: "utilise",               issueIdx: 0,    category: "plain-english" },
        { text: " all resources",         issueIdx: null, category: null }
      ],
      issues: [
        { issueId, absStart, absEnd, category, severity, why, suggested, evidence }
      ]
    },
    improvements: [
      { issueId, severity, category, issue, why, current, suggested }
    ]
  }
#}

<div class="review-output">

  {# ── Scorecard ────────────────────────────────────────────────────────── #}
  {% if reviewData.scores %}
    <div class="govuk-accordion" data-module="govuk-accordion" id="accordion-scores">
      <div class="govuk-accordion__section govuk-accordion__section--expanded">
        <div class="govuk-accordion__section-header">
          <h2 class="govuk-accordion__section-heading">
            <button type="button" id="accordion-scores-heading-1"
                    aria-controls="accordion-scores-content-1"
                    class="govuk-accordion__section-button"
                    aria-expanded="true">
              Content scorecard
            </button>
          </h2>
        </div>
        <div id="accordion-scores-content-1"
             class="govuk-accordion__section-content"
             aria-labelledby="accordion-scores-heading-1">
          <dl class="govuk-summary-list">
            {% for category, scoreData in reviewData.scores %}
              <div class="govuk-summary-list__row">
                <dt class="govuk-summary-list__key">{{ category }}</dt>
                <dd class="govuk-summary-list__value">
                  <span class="score-value">{{ scoreData.score }}/5</span>
                  {% if scoreData.note %}
                    <span class="score-separator"> — </span>
                    <span class="score-note">{{ scoreData.note }}</span>
                  {% endif %}
                </dd>
              </div>
            {% endfor %}
          </dl>
        </div>
      </div>
    </div>

    <style>
      #accordion-scores .govuk-accordion__show-all { display: none !important; }

      .score-separator { color: #505a5f; font-weight: normal; }

      /* Highlight colours per category */
      mark.highlight-plain-english  { background: #fff0c8; }
      mark.highlight-govuk-style    { background: #d4edff; }
      mark.highlight-accessibility  { background: #ffe0e0; }
      mark.highlight-tone           { background: #e0ffe0; }
      mark.highlight-general        { background: #f0e0ff; }

      a.highlight-link { text-decoration: none; color: inherit; }
      a.highlight-link:hover mark,
      a.highlight-link:focus mark  { outline: 3px solid #ffdd00; outline-offset: 1px; cursor: pointer; }

      html { scroll-behavior: smooth; }

      .improvement-item:target {
        outline: 3px solid #1d70b8;
        outline-offset: 4px;
        background-color: #e8f4fd;
        border-radius: 4px;
      }
    </style>
  {% endif %}

  {# ── Annotated content ───────────────────────────────────────────────── #}
  <section class="reviewed-content govuk-!-margin-top-6">
    <h2 class="govuk-heading-m">Your content (issues highlighted)</h2>

    {%- if reviewData.reviewedContent and reviewData.reviewedContent.annotatedSections
          and reviewData.reviewedContent.annotatedSections.length > 0 -%}
      <div class="content-body govuk-body">
        {%- for section in reviewData.reviewedContent.annotatedSections -%}
          {%- if section.issueIdx is not null and section.issueIdx is not undefined -%}
            {%- set categoryClass = 'highlight-' + (section.category | lower | replace(' ', '-')) -%}
            <a href="#improvement-{{ section.issueIdx }}" class="highlight-link"><mark class="{{ categoryClass }}">{{ section.text }}</mark></a>
          {%- else -%}
            {{ section.text }}
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- elif reviewData.reviewedContent and reviewData.reviewedContent.issues
            and reviewData.reviewedContent.issues.length > 0 -%}
      {# Fallback: no annotatedSections but issues exist — list evidence spans only #}
      <div class="content-body govuk-body">
        {% for issue in reviewData.reviewedContent.issues %}
          <a href="#improvement-{{ loop.index0 }}" class="highlight-link">
            <mark class="highlight-{{ issue.category | lower | replace(' ', '-') }}">{{ issue.evidence }}</mark>
          </a>{{ ' ' }}
        {% endfor %}
      </div>
    {%- else -%}
      <div class="content-body govuk-body"><p>No content available for annotation.</p></div>
    {%- endif -%}
  </section>

  {# ── Priority Improvements ───────────────────────────────────────────── #}
  <section class="example-improvements govuk-!-margin-top-6">
    <h2 class="govuk-heading-m">Priority improvements</h2>
    {% if reviewData.improvements and reviewData.improvements.length > 0 %}
      <ol class="improvement-list govuk-list govuk-list--number">
        {% for improvement in reviewData.improvements %}
          <li id="improvement-{{ loop.index0 }}"
              class="improvement-item severity-{{ improvement.severity }} govuk-!-margin-bottom-4">
            <span class="govuk-tag govuk-tag--blue govuk-!-margin-right-2">{{ improvement.category }}</span>
            <strong class="issue-title govuk-body-l">{{ improvement.issue }}</strong>
            <p class="issue-description govuk-body">{{ improvement.why }}</p>
            {% if improvement.current or improvement.suggested %}
              <div class="issue-example govuk-inset-text">
                {% if improvement.current %}
                  <p class="before-text govuk-body">
                    <strong>Current:</strong> {{ improvement.current }}
                  </p>
                {% endif %}
                {% if improvement.suggested %}
                  <p class="after-text govuk-body">
                    <strong>Suggested:</strong> {{ improvement.suggested }}
                  </p>
                {% endif %}
              </div>
            {% endif %}
          </li>
        {% endfor %}
      </ol>
    {% else %}
      <p class="govuk-body">No improvements suggested.</p>
    {% endif %}
  </section>

</div>
